                tds:StorageType lists the acceptable values for type attribute
                Region [string]
                Optional region of the storage server
                LocalPath - optional; [anyURI]
                Local path
                StorageUri - optional; [anyURI]
                Storage server address
                User - optional; [UserCredential]
                User credential for the storage server
                    UserName [string]
                    User name
                    Password - optional; [string]
                    optional password
                    Extension - optional;
                    Token - optional; [string]
                    optional access token
                Extension - optional;
                CertPathValidationPolicyID - optional; [string]
